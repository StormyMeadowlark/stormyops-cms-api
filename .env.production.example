NODE_ENV=production
PORT=2025

MONGO_URI=mongodb+srv://USERNAME:PASSWORD@YOUR_PROD_CLUSTER.mongodb.net/stormyops_cms?retryWrites=true&w=majority

SESSION_COOKIE_NAME=stormyops_session
SESSION_TTL_DAYS=14
COOKIE_DOMAIN=.stormyops.com

CORS_ORIGINS=https://stormyops.com,https://www.stormyops.com

TENANT_ID=stormyops

REDIS_URL=redis://YOUR_PRODUCTION_REDIS_HOST:6379

DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=stormyops-media
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_KEY=your-production-key
DO_SPACES_SECRET=your-production-secret
DO_SPACES_CDN_BASE_URL=https://stormyops-media.nyc3.cdn.digitaloceanspaces.com